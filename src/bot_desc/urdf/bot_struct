<?xml version="1.0"?>
<robot name="box_car">

    <link name="base_link">
        </link>

    <joint name="base_to_chasis_joint" type="fixed">
        <parent link="base_link"/>
        <child link="chasis"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>

    <link name="chasis">
        <visual>
            <origin xyz="0 0 0.1" rpy="0 0 0"/>
            <geometry>
                <box size="0.8 0.4 0.2" />
            </geometry>
            <material name="blue">
                <color rgba="0 0 1 1" />
            </material>        
        </visual>
    </link>

</robot>